# Copy to .env and fill in. Scripts and the agent read these.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# Gemini model the agent uses (use a concrete Vertex version, not a -latest alias).
ADS_MODEL=gemini-2.5-flash

# GCS staging bucket Agent Engine uses for deployment artifacts (no gs:// prefix).
ADS_STAGING_BUCKET=your-gcp-project-id-ads-staging

# GCS bucket where ADS documents are staged for RAG ingestion (no gs:// prefix).
ADS_DATA_BUCKET=your-gcp-project-id-ads-data

# --- Filled in by the setup scripts, then paste back here ---
# Printed by scripts/02_create_rag_corpus.py
ADS_RAG_CORPUS=
# Printed by scripts/03_create_model_armor.py
ADS_MODEL_ARMOR_INPUT_TEMPLATE=
ADS_MODEL_ARMOR_OUTPUT_TEMPLATE=
# Printed by scripts/04_deploy_agent_engine.py
ADS_AGENT_ENGINE_RESOURCE=

# Cloud Logging log name for prompt/response audit trail.
ADS_LOG_NAME=ads-agent-interactions
